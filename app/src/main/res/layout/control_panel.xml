<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#99000000"
    android:elevation="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Drag to Move Panel"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:paddingBottom="8dp"/>

    <Spinner
        android:id="@+id/spinner_mode"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:background="#44FFFFFF"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Opacity"
        android:textColor="#FFFFFF" />
    <SeekBar
        android:id="@+id/slider_opacity"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:max="255"
        android:progress="255"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thickness"
        android:textColor="#FFFFFF" />
    <SeekBar
        android:id="@+id/slider_thickness"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:max="20"
        android:progress="5"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btn_color_white"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:backgroundTint="#FFFFFF"
            android:layout_margin="4dp"/>
        <Button
            android:id="@+id/btn_color_black"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:backgroundTint="#000000"
            android:layout_margin="4dp"/>
        <Button
            android:id="@+id/btn_color_neon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:backgroundTint="#39FF14"
            android:layout_margin="4dp"/>
        <Button
            android:id="@+id/btn_color_yellow"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:backgroundTint="#FFFF00"
            android:layout_margin="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/btn_lock"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Lock" />
        <Button
            android:id="@+id/btn_close"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Close" />
    </LinearLayout>
</LinearLayout>
